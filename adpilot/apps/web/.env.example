# Supabase (project settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Meta app (developers.facebook.com -> your app -> App settings -> Basic)
META_APP_ID=
META_APP_SECRET=

# Where the app runs — must match the OAuth redirect URI registered with Meta:
# {NEXT_PUBLIC_APP_URL}/api/meta/oauth/callback
NEXT_PUBLIC_APP_URL=http://localhost:3000

# 32-byte hex key for encrypting Meta tokens at rest: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=

# Dev login mode: browse the dashboard with dummy data, no Supabase/Meta needed. NEVER in prod.
# NEXT_PUBLIC_DEV_LOGIN=1

# Live agent: set to enable the real Claude agent behind /api/chat
# ANTHROPIC_API_KEY=sk-ant-...

# Stripe (M4 billing)
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_PRICE_ID=price_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# WhatsApp Cloud (M4 module) — same Meta app as above, + the WhatsApp product
# and an Embedded Signup config. NEXT_PUBLIC_* vars are read client-side by
# the connect button; without them it falls back to the dev-only connect path.
# NEXT_PUBLIC_META_APP_ID=              (same value as META_APP_ID)
# NEXT_PUBLIC_WA_SIGNUP_CONFIG_ID=      (Meta app -> WhatsApp -> Embedded Signup)
# WA_WEBHOOK_VERIFY_TOKEN=              (any random string; set the same value
#                                         in the Meta webhook subscription form)
